# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=your-mongodb-connection-string

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-another-long-random-secret
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:3000
